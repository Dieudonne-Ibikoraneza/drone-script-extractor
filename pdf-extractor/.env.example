# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# File Processing
MAX_FILE_SIZE=10485760  # 10MB in bytes

# CORS Configuration
CORS_ORIGINS=*

# Cloudinary (required for map image upload)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=starhawk-report-images
